# ─────────────────────────────────────────────
# Tool-95 — Cyber Asset Discovery Scanner
# Copy this file to .env and fill in your values
# NEVER commit the actual .env to GitHub
# ─────────────────────────────────────────────

# ── Groq AI ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── AI Service ───────────────────────────────
AI_PORT=5000
FLASK_DEBUG=false

# ── Database ─────────────────────────────────
POSTGRES_DB=tool95db
POSTGRES_USER=tool95user
POSTGRES_PASSWORD=your_db_password_here
DB_HOST=postgres
DB_PORT=5432

# ── Redis ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars
JWT_EXPIRY_HOURS=24

# ── Mail ─────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ── Backend ──────────────────────────────────
BACKEND_PORT=8080
AI_SERVICE_BASE_URL=http://ai-service:5000
